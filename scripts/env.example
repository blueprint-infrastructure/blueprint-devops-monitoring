# Amazon Managed Grafana (AMG) Configuration
AMG_WORKSPACE_ID=g-69cf066ee8
AMG_REGION=us-east-1

# DO NOT EDIT AMG_API_KEY - The script will automatically create API keys as needed
# Setting this manually is not recommended and may cause deployment failures
# AMG_ENDPOINT is optional - script will auto-detect from workspace
# AMG_ENDPOINT=your-workspace-id.grafana-workspace.us-east-1.amazonaws.com

# Dashboard deployment options
OVERWRITE=true

# Alert deployment options
# DATASOURCE_UID is the UID of your Prometheus datasource in Grafana
# You can find it in Grafana: Configuration -> Data sources -> Click on datasource -> Check URL for uid
DATASOURCE_UID=prometheus

# Notification Configuration
# Microsoft Teams incoming webhook URL for alert notifications
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# SES email for critical alerts
# ALERT_EMAIL_SENDER=staking-alert@yourdomain.com
# ALERT_EMAIL_RECIPIENTS=alerts-dl@yourdomain.com

# SNS + Lambda Infrastructure (set after running deploy-sns-lambda.sh)
# These are output by deploy-sns-lambda.sh and used by deploy-notifications-amg.sh
# STAKING_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:staking-alert
# STAKING_ALERT_CRITICAL_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:staking-alert-critical
# SNS_TOPIC_NAME=staking-alert
# SNS_CRITICAL_TOPIC_NAME=staking-alert-critical
# LAMBDA_FUNCTION_NAME=staking-alert-teams-notifier

# AWS Configuration (if not using default profile)
# AWS_PROFILE=your-profile-name
# AWS_REGION=us-east-1
